TELEGRAM_BOT_TOKEN=123456:replace_with_your_telegram_bot_token
OPENAI_API_KEY=sk-replace_with_your_openai_api_key

# Optional but recommended. Send /whoami to the bot, then put your numeric ID here.
TELEGRAM_ALLOWED_USER_IDS=

# Optional. Set this to the model you want the API bot to use.
OPENAI_MODEL=gpt-4.1-mini

# Public production URL used in account verification links.
NEXT_PUBLIC_SITE_URL=https://ai-asap.vercel.app

# Optional. Uses OPENAI_MODEL if unset.
OPENAI_PROMPT_BRAIN_MODEL=gpt-4.1-mini

# Optional. Used for Telegram voice-note transcription.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# LiveAvatar aiASAP 6 config. Keep the real API key only in .env/Vercel.
LIVEAVATAR_API_URL=https://api.liveavatar.com
LIVEAVATAR_API_KEY=replace_with_your_liveavatar_api_key
LIVEAVATAR_AVATAR_ID=3cbe98e4-50ff-4e48-8954-7685fcf09dac
LIVEAVATAR_CONTEXT_ID=33a7aeb4-cd4a-4ae3-a2ed-39abf8db2930
LIVEAVATAR_VOICE_ID=a65a59af-39bd-4f57-8cc6-235449ca3348

# Supabase aiASAP database. Use the aiASAP project only, never iSolve.
SUPABASE_URL=https://your-aiasap-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_aiasap_service_role_key
AIASAP_MEDIA_BUCKET=aiasap-media
AIASAP_ACCOUNT_BUCKET=aiasap-accounts
AIASAP_ALLOW_ANON_MEDIA_CAPTURE=false

# Optional. Lets 6 send account links and email bug reports to the Creator/Builder/Founder/Financier/CEO aiASAP.
# Use a Resend sending-access API key restricted to the verified aiASAP sending domain.
AIASAP_FOUNDER_REPORT_EMAIL=creator@example.com
RESEND_API_KEY=re_replace_with_your_resend_key
BUG_REPORT_FROM_EMAIL=aiASAP <bugs@aiasap.ai>
ACCOUNT_LINK_FROM_EMAIL=aiASAP <accounts@aiasap.ai>

# Optional. Google Calendar + Gmail user connection.
# Add this redirect URI in Google Cloud OAuth credentials:
# https://aiasap.ai/api/integrations/google/callback
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://aiasap.ai/api/integrations/google/callback
# Generate with: openssl rand -base64 32
INTEGRATION_TOKEN_ENCRYPTION_KEY=replace_with_32_byte_random_secret
INTEGRATION_STATE_SECRET=replace_with_separate_random_secret
